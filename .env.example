# Database
POSTGRES_USER=gymerviet
POSTGRES_PASSWORD=gymerviet123
POSTGRES_DB=gymerviet
DATABASE_URL=postgresql://gymerviet:gymerviet123@postgres:5432/gymerviet

# Security & Auth
JWT_SECRET=super_secret_jwt_key_example
JWT_REFRESH_SECRET=super_secret_refresh_key_example
JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_TTL_SECONDS=604800

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://redis:6379

# Features
RUN_SEED=false
SKIP_RATE_LIMIT=true
