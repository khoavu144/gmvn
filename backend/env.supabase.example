# --- Chạy backend + migration trực tiếp với Postgres trên Supabase ---
# Sao chép: cp env.supabase.example .env   (hoặc merge vào backend/.env / .env ở root repo)
#
# Dashboard → Project Settings → Database → Connection string → URI.
#
# (A) KHUYẾN NGHỊ cho npm run migrate:run — tab "Direct connection"
#     User: postgres   | Host: db.<PROJECT_REF>.supabase.co | Port: 5432
#
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_URL_ENCODED@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
#
# (B) Pooler (Transaction mode) — tab "Transaction pooler" / port 6543
#     User: postgres.<PROJECT_REF>  (có dấu chấm + ref, KHÔNG chỉ "postgres")
#     Mật khẩu có ký tự @ trong chuỗi gốc → trong URL phải là %40
#
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Dùng một dòng; không bọc nháy kép trong .env trừ khi giá trị có khoảng trắng.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_URL_ENCODED@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Bắt buộc cho server (login, API). Đặt chuỗi ngẫu nhiên đủ dài, không commit file .env thật.
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379

# Upload ảnh / storage (Dashboard → Project Settings → API)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Tuỳ chọn: ép SSL nếu host không chứa supabase.co (ví dụ pooler khác)
# DATABASE_SSL=true

# Observability / alerting (khuyến nghị cho staging/production)
# SENTRY_DSN=https://<public_key>@o<org>.ingest.sentry.io/<project_id>
# SENTRY_ENVIRONMENT=staging
# SENTRY_RELEASE=2026.03.23
# OPS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# ALERT_READINESS_CONSECUTIVE_FAILURES=3
# ALERT_EMAIL_OUTBOX_PENDING_THRESHOLD=50
# ALERT_WEBHOOK_FAILED_WINDOW_MINUTES=30
# ALERT_WEBHOOK_FAILED_THRESHOLD=5
# ALERT_COOLDOWN_SECONDS=900
