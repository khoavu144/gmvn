# Copy to .env.local — never commit secrets.
# VITE_API_URL=https://api.example.com/api/v1
# VITE_CANONICAL_BASE_URL=https://gymerviet.com
# VITE_SENTRY_DSN=https://<public_key>@o<org>.ingest.sentry.io/<project_id>
# VITE_SENTRY_ENVIRONMENT=staging
# VITE_SENTRY_RELEASE=2026.03.23

# Playwright: hit production smoke (optional)
# PLAYWRIGHT_BASE_URL=https://gymerviet.com

# Optional authenticated E2E (e2e/auth.spec.ts)
# E2E_LOGIN_EMAIL=
# E2E_LOGIN_PASSWORD=
#
# GitHub Actions: add repository secrets E2E_LOGIN_EMAIL / E2E_LOGIN_PASSWORD
# so CI runs auth.spec.ts (see .github/workflows/frontend-e2e.yml).
